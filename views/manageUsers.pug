extends base

block content
  main.main
    .user-view
      .user-view__content
        .user-view__form-container(style="max-width: 100%;")
          h2.heading-secondary.ma-bt-md Manage Users
          
          table.admin-table(style="width: 100%; border-collapse: collapse;")
            thead
              tr(style="border-bottom: 2px solid #eee; text-align: center;")
                th.card__sub-heading(style="padding: 1rem;") Avatar
                th.card__sub-heading(style="padding: 1rem;") Name
                th.card__sub-heading(style="padding: 1rem;") Email
                th.card__sub-heading(style="padding: 1rem;") Role
                th.card__sub-heading(style="padding: 1rem;") Actions
            tbody
              each user in users
                tr(style="border-bottom: 1px solid #eee;" data-user-id=user.id)
                  td.card__text(style="padding: 1rem;"): img(src=`/img/users/${user.photo}`, alt=user.name, style="width: 3.5rem; height: 3.5rem; border-radius: 50%; object-fit: cover;")
                  td.card__text(style="padding: 1rem;").user-name= user.name
                  td.card__text(style="padding: 1rem;").user-email= user.email
                  td.card__text.user-role(style=`text-transform: uppercase; font-weight: bold; padding: 1rem; color: ${user.role === 'admin' ? '#ff7730' : '#55c57a'}` data-role=user.role)= user.role
                  td.card__text
                    button.btn.btn--small.btn--green.btn--admin-edit-user(style=" font-size: 1.1rem; margin-right: 0.5rem;") Edit
                    button.btn.btn--small.btn--red.btn--admin-delete-user(style=" font-size: 1.1rem;") Delete

  .user-modal.hidden(style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 4rem; z-index: 1000; box-shadow: 0 3rem 5rem rgba(0,0,0,0.3); border-radius: 5px; width: 50rem;")
    h3.heading-secondary.ma-bt-md Administrative User Edit
    form.form.form--admin-edit-user
      .form__group
        label.form__label Name
        input#modal-user-name.form__input(type='text', required)
      .form__group
        label.form__label Email
        input#modal-user-email.form__input(type='email', required)
      .form__group.ma-bt-md
        label.form__label System Role
        select#modal-user-role.form__input(style="height: 5rem;")
          option(value="user") User
          option(value="guide") Guide
          option(value="lead-guide") Lead-Guide
          option(value="admin") Admin
      .form__group(style="display: flex; justify-content: flex-end; margin-top: 2.5rem;")
        button.btn.btn--green Save Settings
        button.btn.btn--gray.btn--close-user-modal(type='button' style='margin-left: 1rem;') Cancel

  .user-modal-overlay.hidden(style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999; backdrop-filter: blur(4px);")