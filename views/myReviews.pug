extends base

block content
  main.main
    .user-view#my-reviews-page
      .user-view__content
        div#my-reviews-container(style="padding: 0 20rem")
          h2.heading-secondary.ma-bt-md My Reviews
          
          if reviews.length === 0
            p.text(style="font-size: 1.5rem;") You haven't written any reviews yet!
          else
            each review in reviews
              .card(style="padding: 2rem; margin-bottom: 2rem; box-shadow: 0 1rem 3rem rgba(0,0,0,0.05);")
                a(href=`/tour/${review.tour.slug}` style="text-decoration: none; color: inherit;")
                  h4(style="font-size: 1.5rem; margin-bottom: 1rem;")= review.tour.name
                p.review__text(style="font-size: 1.2rem; margin-bottom: 1rem;")= review.review
                .review__rating
                  each star in [1, 2, 3, 4, 5]
                    svg.reviews__star(class=`reviews__star--${star <= review.rating ? 'active' : 'inactive'}`)
                      use(xlink:href='/img/icons.svg#icon-star')
                
                //- Add action buttons for updates/deletes
                .review__actions(style="margin-top: 1.5rem;")
                  button.btn.btn--small.btn--green.btn--edit-review(data-review-id=review.id) Edit
                  button.btn.btn--small.btn--red.btn--delete-review(data-review-id=review.id style="margin-left: 1rem;") Delete



  //- Add this at the very bottom of myReviews.pug, outside the main layout container
  .edit-modal.hidden(style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 4rem; z-index: 1000; box-shadow: 0 3rem 5rem rgba(0,0,0,0.3); border-radius: 5px; width: 50rem;")
    h3.heading-secondary.ma-bt-md Edit Your Review
    form.form.form--edit-review
      .form__group
        label.form__label(for='modal-review-text') Your Review
        textarea#modal-review-text.form__input(name='review', placeholder='Tell us about your experience...', required, rows='4')
      .form__group
        label.form__label(for='modal-review-rating') Rating (1-5)
        .reviews__rating(style="cursor: pointer;")
          each star in [1, 2, 3, 4, 5]
            svg.reviews__star(data-star-value=star)
              use(xlink:href='/img/icons.svg#icon-star')
        //- Hidden input to store the actual rating value for form submission
        input#modal-review-rating.reviews__star-radio(type='hidden', name='rating', value='1')
      .form__group
        button.btn.btn--green Save Changes
        button.btn.btn--gray.btn--close-modal(type='button' style='margin-left: 1rem;') Cancel

  .modal-overlay.hidden(style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999;")

  script(type="module").
    import { showAlert } from '/js/alerts.js';

    // Star rating interactivity for the modal
    const modalStars = document.querySelectorAll('.edit-modal .reviews__star');
    const modalRatingContainer = document.querySelector('.edit-modal .reviews__rating');
    const modalRatingInput = document.getElementById('modal-review-rating');
    let modalCurrentRating = 1; // Default

    const updateModalStars = (rating) => {
      modalStars.forEach(star => {
        star.classList.toggle('reviews__star--active', star.dataset.starValue <= rating);
        star.classList.toggle('reviews__star--inactive', star.dataset.starValue > rating);
      });
    };

    // Event listeners for modal stars
    modalStars.forEach(star => {
      star.addEventListener('mouseover', () => {
        const hoverRating = star.dataset.starValue;
        updateModalStars(hoverRating);
      });

      star.addEventListener('click', () => {
        modalCurrentRating = star.dataset.starValue;
        modalRatingInput.value = modalCurrentRating; // Update hidden input
      });
    });

    modalRatingContainer.addEventListener('mouseleave', () => {
      updateModalStars(modalCurrentRating);
    });

    // Listen for when the modal is opened and populated by index.js
    const editModal = document.querySelector('.edit-modal');
    editModal.addEventListener('reviewModalOpened', () => {
      // Read the rating that was set by index.js into the hidden input
      modalCurrentRating = parseInt(modalRatingInput.value, 10);
      updateModalStars(modalCurrentRating);
    });

    // The form submission for the modal is handled in index.js,
    // this script primarily manages the visual star rating and updates the hidden input.
    // The existing editForm listener in index.js will pick up the value from modalRatingInput.