extends base

block content
  main.main
    .user-view
      
      .user-view__content
        div(style="padding: 0 20rem")
          h2.heading-secondary.ma-bt-md My Reviews
          
          if reviews.length === 0
            p.text You haven't written any reviews yet!
          else
            each review in reviews
              .card(style="padding: 2rem; margin-bottom: 2rem; box-shadow: 0 1rem 3rem rgba(0,0,0,0.05);")
                h4= review.tour.name
                p.review__text= review.review
                .review__rating
                  each star in [1, 2, 3, 4, 5]
                    svg.reviews__star(class=`reviews__star--${star <= review.rating ? 'active' : 'inactive'}`)
                      use(xlink:href='/img/icons.svg#icon-star')
                
                //- Add action buttons for updates/deletes
                .review__actions(style="margin-top: 1.5rem;")
                  button.btn.btn--small.btn--green.btn--edit-review(data-review-id=review.id) Edit
                  button.btn.btn--small.btn--red.btn--delete-review(data-review-id=review.id style="margin-left: 1rem;") Delete



  //- Add this at the very bottom of myReviews.pug, outside the main layout container
  .edit-modal.hidden(style="position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: white; padding: 4rem; z-index: 1000; box-shadow: 0 3rem 5rem rgba(0,0,0,0.3); border-radius: 5px; width: 50rem;")
    h3.heading-secondary.ma-bt-md Edit Your Review
    form.form.form--edit-review
      .form__group
        label.form__label(for='modal-review-text') Review Message
        textarea#modal-review-text.form__input(rows='4', required)
      .form__group.ma-bt-md
        label.form__label(for='modal-review-rating') Rating (1-5)
        input#modal-review-rating.form__input(type='number', min='1', max='5', required)
      .form__group
        button.btn.btn--green Save Changes
        button.btn.btn--gray.btn--close-modal(type='button' style='margin-left: 1rem;') Cancel

  .modal-overlay.hidden(style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 999;")